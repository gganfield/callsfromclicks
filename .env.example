# Resend (sends audit + contact form emails to you)
# Get an API key at https://resend.com
RESEND_API_KEY=

# Where to send audit form submissions (optional; defaults to garrett@callsfromclicks.com)
# AUDIT_TO_EMAIL=garrett@callsfromclicks.com

# ── Referral Code System ──────────────────────────────────────────────────

# SQLite database path (relative to project root)
DATABASE_URL=file:./prisma/dev.db

# Admin panel password (for /admin)
ADMIN_PASSWORD=

# API key for /api/clients/create (used by Cowork or external callers)
CLIENTS_API_KEY=

# Secret used to sign client session cookies (any long random string)
COOKIE_SECRET=
