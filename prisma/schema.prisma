generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Client {
  id           Int      @id @default(autoincrement())
  clientNumber String   @unique
  slug         String   @unique
  name         String
  phone        String
  passwordHash String?
  createdAt    DateTime @default(now())
  status       String   @default("pending_first_login")
  codes        Code[]
}

model Code {
  id           Int       @id @default(autoincrement())
  clientId     Int
  client       Client    @relation(fields: [clientId], references: [id])
  code         String    @unique
  jobType      String
  jobTypeShort String
  clientName   String
  amount       String
  status       String    @default("unused")
  createdAt    DateTime  @default(now())
  expiresAt    DateTime
  usedAt       DateTime?
}
